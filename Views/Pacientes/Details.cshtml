@model SighApp.Models.Paciente
@{
    ViewData["Title"] = "Expediente del Paciente";
    var historial = ViewBag.Historial as IEnumerable<SighApp.Models.Diagnostico> ?? new List<SighApp.Models.Diagnostico>();
}

<div class="container-fluid animate-fade-in">
    <!-- Navegación de regreso -->
    <div class="mb-4">
        <a asp-action="Index" class="text-decoration-none text-muted mb-2 d-inline-flex align-items-center gap-1">
            <i class="bi bi-arrow-left"></i> Volver al listado
        </a>
        <h1 class="h3 fw-bold text-dark mb-1">Expediente Clínico Digital</h1>
        <p class="text-muted">Ficha filiativa e historial de diagnósticos y tratamientos de "Salud Total".</p>
    </div>

    <div class="row">
        <!-- Columna Izquierda: Ficha de Filiación -->
        <div class="col-lg-4">
            <div class="card-clinical position-sticky" style="top: 20px;">
                <div class="card-clinical-body text-center pt-4">
                    <div class="avatar bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold mx-auto mb-3" style="width: 80px; height: 80px; font-size: 2.2rem; box-shadow: 0 4px 10px rgba(13, 110, 253, 0.2);">
                        @Model.Nombre[0]@Model.Apellido[0]
                    </div>
                    <h4 class="fw-bold text-dark mb-1">@Model.Nombre @Model.Apellido</h4>
                    <span class="badge bg-light text-primary border border-primary px-3 py-2 rounded-pill fw-semibold fs-7 mb-4">Cédula: @Model.Cedula</span>

                    <hr class="text-muted opacity-25">

                    <div class="text-start mt-3">
                        <div class="mb-3">
                            <span class="text-muted d-block" style="font-size: 0.8rem; font-weight: 600;">GÉNERO</span>
                            <span class="text-dark fw-medium">
                                <i class="bi @(Model.Genero == "Masculino" ? "bi-gender-male text-primary" : "bi-gender-female text-danger") me-2"></i>
                                @Model.Genero
                            </span>
                        </div>
                        <div class="mb-3">
                            <span class="text-muted d-block" style="font-size: 0.8rem; font-weight: 600;">FECHA DE NACIMIENTO</span>
                            <span class="text-dark fw-medium">
                                <i class="bi bi-calendar-check-fill text-muted me-2"></i>
                                @Model.FechaNacimiento.ToString("dd MMMM yyyy")
                            </span>
                        </div>
                        <div class="mb-3">
                            <span class="text-muted d-block" style="font-size: 0.8rem; font-weight: 600;">TELÉFONO</span>
                            <span class="text-dark fw-medium">
                                <i class="bi bi-telephone-fill text-muted me-2"></i>
                                @Model.Telefono
                            </span>
                        </div>
                        <div class="mb-3">
                            <span class="text-muted d-block" style="font-size: 0.8rem; font-weight: 600;">CORREO ELECTRÓNICO</span>
                            <span class="text-dark fw-medium" style="word-break: break-all;">
                                <i class="bi bi-envelope-fill text-muted me-2"></i>
                                @Model.Email
                            </span>
                        </div>
                        <div class="mb-3">
                            <span class="text-muted d-block" style="font-size: 0.8rem; font-weight: 600;">DIRECCIÓN</span>
                            <span class="text-dark fw-medium">
                                <i class="bi bi-geo-alt-fill text-muted me-2"></i>
                                @(string.IsNullOrWhiteSpace(Model.Direccion) ? "No especificada" : Model.Direccion)
                            </span>
                        </div>
                        <div class="mb-2">
                            <span class="text-muted d-block" style="font-size: 0.8rem; font-weight: 600;">FECHA DE REGISTRO</span>
                            <span class="text-muted fw-medium" style="font-size: 0.9rem;">
                                <i class="bi bi-clock-history me-2"></i>
                                @Model.FechaRegistro.ToString("dd/MM/yyyy hh:mm tt")
                            </span>
                        </div>
                    </div>

                    <div class="mt-4 pt-2 border-top d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-clinical-primary flex-grow-1">
                            <i class="bi bi-pencil-square me-1"></i> Editar Ficha
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Columna Derecha: Historial Clínico Timeline -->
        <div class="col-lg-8">
            <div class="card-clinical">
                <div class="card-clinical-header">
                    <h5 class="card-clinical-title d-flex align-items-center gap-2">
                        <i class="bi bi-clipboard2-pulse-fill text-primary"></i>
                        Historial Médico y Consultas Realizadas
                    </h5>
                    <span class="badge-clinical badge-clinical-info">@historial.Count() Consultas</span>
                </div>
                <div class="card-clinical-body">
                    @if (!historial.Any())
                    {
                        <div class="text-center py-5 text-muted">
                            <i class="bi bi-journal-medical fs-1 d-block mb-3 text-secondary"></i>
                            <h6 class="fw-bold text-dark mb-1">Sin Expedientes de Consulta</h6>
                            <p class="fs-7 max-w-md mx-auto">Este paciente no registra atenciones médicas diagnosticadas en nuestra clínica aún.</p>
                        </div>
                    }
                    else
                    {
                        <div class="timeline-clinical">
                            @foreach (var diag in historial)
                            {
                                <div class="timeline-item animate-fade-in">
                                    <div class="timeline-date">@diag.FechaDiagnostico.ToString("dd MMMM yyyy, hh:mm tt")</div>
                                    <div class="timeline-title">Consulta por: "@diag.MotivoCita"</div>
                                    <div class="timeline-desc">
                                        <div class="mb-3">
                                            <span class="badge bg-secondary-subtle text-dark border border-secondary-subtle px-2 py-1 mb-2 fs-8">
                                                Atendido por: <strong>@diag.NombreMedico</strong>
                                            </span>
                                            <p class="mb-0 text-dark" style="white-space: pre-line;">
                                                <strong>Descripción del Diagnóstico:</strong><br>
                                                @diag.Descripcion
                                            </p>
                                        </div>

                                        @if (diag.Tratamientos != null && diag.Tratamientos.Any())
                                        {
                                            <div class="mt-3 pt-3 border-top border-slate">
                                                <h6 class="fw-bold text-primary mb-2" style="font-size: 0.9rem;">
                                                    <i class="bi bi-prescription2 me-1"></i>
                                                    Tratamientos Recetados:
                                                </h6>
                                                <div class="table-responsive rounded-3 border border-slate bg-white">
                                                    <table class="table table-sm table-borderless mb-0 px-2 py-1" style="font-size: 0.85rem;">
                                                        <thead class="table-light">
                                                            <tr>
                                                                <th>Medicamento</th>
                                                                <th>Dosis</th>
                                                                <th>Frecuencia</th>
                                                                <th>Duración</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            @foreach (var trat in diag.Tratamientos)
                                                            {
                                                                <tr>
                                                                    <td class="fw-semibold text-dark">@trat.Medicamento</td>
                                                                    <td>@trat.Dosis</td>
                                                                    <td>@trat.Frecuencia</td>
                                                                    <td><span class="badge bg-info text-dark">@trat.Duracion</span></td>
                                                                </tr>
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

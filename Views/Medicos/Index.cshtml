@model IEnumerable<SighApp.Models.Medico>
@{
    ViewData["Title"] = "Gestión de Médicos";
    var especialidades = ViewBag.Especialidades as IEnumerable<SighApp.Models.Especialidad> ?? new List<SighApp.Models.Especialidad>();
}

<div class="container-fluid animate-fade-in">
    <!-- Header de Módulo -->
    <div class="row align-items-center mb-4">
        <div class="col">
            <h1 class="h3 fw-bold text-dark mb-1">Médicos</h1>
            <p class="text-muted mb-0">Administración del personal médico, especialidades y horarios de atención.</p>
        </div>
        <div class="col-auto">
            <a asp-action="Create" class="btn btn-clinical-primary">
                <i class="bi bi-person-badge-fill me-2"></i> Registrar Médico
            </a>
        </div>
    </div>

    <!-- Filtros y Búsqueda -->
    <div class="card-clinical mb-4">
        <div class="card-clinical-body">
            <div class="row g-3">
                <!-- Buscar por Nombre -->
                <div class="col-md-6">
                    <label class="form-clinical-label">Filtrar por nombre o licencia</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 border-slate">
                            <i class="bi bi-search text-muted"></i>
                        </span>
                        <input type="text" id="medicoSearch" class="form-control form-clinical-control border-start-0" placeholder="Escriba nombre, apellido o licencia..." value="@ViewBag.Search">
                    </div>
                </div>
                <!-- Filtrar por Especialidad -->
                <div class="col-md-6">
                    <label class="form-clinical-label">Filtrar por Especialidad</label>
                    <select id="especialidadFilter" class="form-select form-clinical-control">
                        <option value="">-- Todas las Especialidades --</option>
                        @foreach (var esp in especialidades)
                        {
                            <option value="@esp.Id" selected="@(ViewBag.SelectedEspecialidadId == esp.Id ? "selected" : null)">@esp.Nombre</option>
                        }
                    </select>
                </div>
            </div>
        </div>
    </div>

    <!-- Contenedor de la Tabla AJAX -->
    <div class="card-clinical">
        <div class="card-clinical-header">
            <h5 class="card-clinical-title">Cuerpo Médico de Salud Total</h5>
            <span class="badge bg-primary rounded-pill" id="medicoCount">@Model.Count() médicos</span>
        </div>
        <div class="table-responsive" id="medicoTableContainer">
            @await Html.PartialAsync("_MedicoTable", Model)
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/medicos.js" asp-append-version="true"></script>
}

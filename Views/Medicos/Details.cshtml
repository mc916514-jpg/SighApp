@model SighApp.Models.Medico
@{
    ViewData["Title"] = "Perfil del Médico";
}

<div class="container-fluid animate-fade-in" style="max-width: 700px;">
    <!-- Navegación de regreso -->
    <div class="mb-4">
        <a asp-action="Index" class="text-decoration-none text-muted mb-2 d-inline-flex align-items-center gap-1">
            <i class="bi bi-arrow-left"></i> Volver al listado
        </a>
        <h1 class="h3 fw-bold text-dark mb-1">Perfil del Profesional</h1>
        <p class="text-muted">Ficha administrativa y especialidad médica.</p>
    </div>

    <!-- Ficha del Médico -->
    <div class="card-clinical">
        <div class="card-clinical-body text-center pt-4">
            <div class="avatar bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold mx-auto mb-3" style="width: 80px; height: 80px; font-size: 2.2rem; box-shadow: 0 4px 10px rgba(13, 110, 253, 0.2);">
                @Model.Nombre[0]@Model.Apellido[0]
            </div>
            <h4 class="fw-bold text-dark mb-1">Dr. @Model.Nombre @Model.Apellido</h4>
            <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-2 rounded-pill fw-semibold fs-7 mb-4">
                @Model.NombreEspecialidad
            </span>

            <hr class="text-muted opacity-25">

            <div class="text-start mt-3">
                <div class="mb-3">
                    <span class="text-muted d-block" style="font-size: 0.8rem; font-weight: 600;">CÉDULA / REGISTRO</span>
                    <span class="text-dark fw-medium">
                        <i class="bi bi-card-text text-muted me-2"></i>
                        @Model.Cedula
                    </span>
                </div>
                <div class="mb-3">
                    <span class="text-muted d-block" style="font-size: 0.8rem; font-weight: 600;">TELÉFONO</span>
                    <span class="text-dark fw-medium">
                        <i class="bi bi-telephone-fill text-muted me-2"></i>
                        @Model.Telefono
                    </span>
                </div>
                <div class="mb-3">
                    <span class="text-muted d-block" style="font-size: 0.8rem; font-weight: 600;">CORREO ELECTRÓNICO</span>
                    <span class="text-dark fw-medium" style="word-break: break-all;">
                        <i class="bi bi-envelope-fill text-muted me-2"></i>
                        @Model.Email
                    </span>
                </div>
                <div class="mb-3">
                    <span class="text-muted d-block" style="font-size: 0.8rem; font-weight: 600;">ESTADO OPERATIVO</span>
                    <span class="text-dark fw-medium">
                        @if (Model.Activo)
                        {
                            <span class="badge-clinical badge-clinical-success">
                                <i class="bi bi-check-circle-fill"></i> Activo / Habilitado
                            </span>
                        }
                        else
                        {
                            <span class="badge-clinical badge-clinical-danger">
                                <i class="bi bi-x-circle-fill"></i> Inactivo / Deshabilitado
                            </span>
                        }
                    </span>
                </div>
            </div>

            <div class="mt-4 pt-2 border-top d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-clinical-primary flex-grow-1">
                    <i class="bi bi-pencil-square me-1"></i> Editar Perfil
                </a>
            </div>
        </div>
    </div>
</div>

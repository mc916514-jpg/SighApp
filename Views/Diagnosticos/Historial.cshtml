@model IEnumerable<SighApp.Models.Diagnostico>
@{
    ViewData["Title"] = "Historial Clínico del Paciente";
    var paciente = ViewBag.Paciente as SighApp.Models.Paciente;
}

<div class="container-fluid animate-fade-in" style="max-width: 900px;">
    <!-- Migas de Pan y Header -->
    <div class="mb-4">
        <a asp-controller="Pacientes" asp-action="Index" class="text-decoration-none text-muted mb-2 d-inline-flex align-items-center gap-1">
            <i class="bi bi-arrow-left"></i> Volver a Pacientes
        </a>
        <h1 class="h3 fw-bold text-dark mb-1">Historial Clínico de Salud</h1>
        <p class="text-muted">Registro histórico confidencial de consultas, diagnósticos y tratamientos prescritos.</p>
    </div>

    <!-- Ficha del Paciente -->
    @if (paciente != null)
    {
        <div class="card-clinical mb-4">
            <div class="card-clinical-body">
                <div class="row align-items-center">
                    <div class="col-auto">
                        <div class="avatar bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold fs-3" style="width: 60px; height: 60px;">
                            @paciente.Nombre[0]@paciente.Apellido[0]
                        </div>
                    </div>
                    <div class="col">
                        <h4 class="fw-bold text-dark mb-1">@paciente.Nombre @paciente.Apellido</h4>
                        <div class="d-flex flex-wrap gap-3 text-muted small mt-1">
                            <span><strong>Cédula:</strong> @paciente.Cedula</span>
                            <span><strong>Edad:</strong> @paciente.Edad años</span>
                            <span><strong>Género:</strong> @paciente.Genero</span>
                        </div>
                    </div>
                    <div class="col-auto mt-2 mt-md-0">
                        <a asp-controller="Pacientes" asp-action="Details" asp-route-id="@paciente.Id" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-person-badge me-1"></i> Ficha del Paciente
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Timeline de Historial Clínico -->
    <div class="card-clinical">
        <div class="card-clinical-header d-flex justify-content-between align-items-center">
            <h5 class="card-clinical-title d-flex align-items-center gap-2">
                <i class="bi bi-clock-history text-muted"></i>
                Línea de Tiempo de Consultas
            </h5>
            <span class="badge bg-primary rounded-pill">@Model.Count() consultas registradas</span>
        </div>
        <div class="card-clinical-body">
            @if (!Model.Any())
            {
                <div class="text-center text-muted py-5">
                    <i class="bi bi-folder-x fs-1 d-block mb-3 text-secondary"></i>
                    <h6 class="fw-bold">No hay consultas en el historial</h6>
                    <p class="small px-4 text-secondary mb-0">Este paciente aún no registra consultas médicas completadas o diagnósticos guardados en el sistema.</p>
                </div>
            }
            else
            {
                <div class="timeline-clinical">
                    @foreach (var diag in Model)
                    {
                        <div class="timeline-clinical-item">
                            <div class="timeline-clinical-badge bg-primary text-white">
                                <i class="bi bi-activity"></i>
                            </div>
                            <div class="timeline-clinical-content">
                                <div class="d-flex flex-wrap justify-content-between align-items-start mb-2 gap-2">
                                    <div>
                                        <h5 class="fw-bold text-dark mb-0">Consulta General</h5>
                                        <small class="text-muted d-block mt-0.5">
                                            Atendido por: <strong>Dr. @diag.NombreMedico</strong>
                                        </small>
                                    </div>
                                    <div class="text-md-end">
                                        <span class="badge bg-light text-dark border px-2 py-1 font-monospace" style="font-size: 0.8rem;">
                                            <i class="bi bi-calendar-event me-1 text-primary"></i>
                                            @diag.FechaDiagnostico.ToString("dd/MM/yyyy - hh:mm tt")
                                        </span>
                                    </div>
                                </div>

                                <div class="bg-light p-3 rounded-3 border mb-3">
                                    <span class="text-muted d-block small mb-1" style="font-weight: 600; font-size: 0.72rem;">DIAGNÓSTICO</span>
                                    <p class="text-dark small mb-0" style="line-height: 1.5; white-space: pre-line;">
                                        @diag.Descripcion
                                    </p>
                                </div>

                                @if (diag.Tratamientos.Any())
                                {
                                    <div class="border-top pt-2">
                                        <span class="text-muted d-block small mb-2" style="font-weight: 600; font-size: 0.72rem; letter-spacing: 0.5px;">RECETA MÉDICA</span>
                                        <div class="row g-2">
                                            @foreach (var tr in diag.Tratamientos)
                                            {
                                                <div class="col-md-6">
                                                    <div class="p-2 border rounded-3 bg-white" style="font-size: 0.82rem;">
                                                        <div class="d-flex justify-content-between">
                                                            <strong class="text-primary">@tr.Medicamento</strong>
                                                            <span class="badge bg-secondary-subtle text-secondary font-monospace" style="font-size: 0.72rem;">@tr.Dosis</span>
                                                        </div>
                                                        <div class="text-muted small mt-1.5" style="font-size: 0.75rem;">
                                                            <strong>Instrucciones:</strong> @tr.Frecuencia | @tr.Duracion
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                                
                                <div class="mt-3 text-end">
                                    <a asp-action="Details" asp-route-id="@diag.Id" class="btn btn-xs btn-outline-secondary">
                                        <i class="bi bi-printer me-1"></i> Imprimir Receta
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

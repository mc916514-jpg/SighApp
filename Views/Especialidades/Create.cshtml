@model SighApp.Models.Especialidad
@{
    ViewData["Title"] = "Crear Especialidad";
}

<div class="container-fluid animate-fade-in" style="max-width: 600px;">
    <!-- Migas de Pan y Header -->
    <div class="mb-4">
        <a asp-action="Index" class="text-decoration-none text-muted mb-2 d-inline-flex align-items-center gap-1">
            <i class="bi bi-arrow-left"></i> Volver al listado
        </a>
        <h1 class="h3 fw-bold text-dark mb-1">Crear Especialidad</h1>
        <p class="text-muted">Añada una nueva rama de atención médica para asignar a nuestro personal de salud.</p>
    </div>

    <!-- Formulario Clínico -->
    <div class="card-clinical">
        <div class="card-clinical-header">
            <h5 class="card-clinical-title">Ficha de Especialidad</h5>
        </div>
        <div class="card-clinical-body">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 border-0 py-2 mb-3" style="font-size: 0.9rem;"></div>

                <div class="row g-3">
                    <!-- Nombre de Especialidad -->
                    <div class="col-md-12">
                        <label asp-for="Nombre" class="form-clinical-label">Nombre de la Especialidad *</label>
                        <input asp-for="Nombre" class="form-control form-clinical-control" placeholder="Ej: Pediatría, Cardiología, Neurología..." />
                        <span asp-validation-for="Nombre" class="validation-error-msg"></span>
                    </div>

                    <!-- Descripción de Especialidad -->
                    <div class="col-md-12">
                        <label asp-for="Descripcion" class="form-clinical-label">Descripción</label>
                        <textarea asp-for="Descripcion" rows="3" class="form-control form-clinical-control" placeholder="Describa brevemente el área de cobertura clínica..."></textarea>
                        <span asp-validation-for="Descripcion" class="validation-error-msg"></span>
                    </div>
                </div>

                <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-clinical-secondary">
                        Cancelar
                    </a>
                    <button type="submit" class="btn btn-clinical-primary">
                        <i class="bi bi-save me-1"></i> Crear Especialidad
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

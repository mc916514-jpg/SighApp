@model SighApp.Models.Cita
@{
    ViewData["Title"] = "Agendar Nueva Cita";
    var pacientes = ViewBag.Pacientes as IEnumerable<SighApp.Models.Paciente> ?? new List<SighApp.Models.Paciente>();
    var medicos = ViewBag.Medicos as IEnumerable<SighApp.Models.Medico> ?? new List<SighApp.Models.Medico>();
}

<div class="container-fluid animate-fade-in" style="max-width: 800px;">
    <!-- Migas de Pan y Header -->
    <div class="mb-4">
        <a asp-action="Index" class="text-decoration-none text-muted mb-2 d-inline-flex align-items-center gap-1">
            <i class="bi bi-arrow-left"></i> Volver a la agenda
        </a>
        <h1 class="h3 fw-bold text-dark mb-1">Agendar Cita Médica</h1>
        <p class="text-muted">Programe una nueva cita validando de forma interactiva la agenda y horarios del médico.</p>
    </div>

    <!-- Formulario Clínico con Validación AJAX -->
    <div class="card-clinical">
        <div class="card-clinical-header">
            <h5 class="card-clinical-title">Asignación de Paciente, Médico y Horarios</h5>
        </div>
        <div class="card-clinical-body">
            <form asp-action="Create" method="post" id="citaCreateForm">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 border-0 py-2 mb-3" style="font-size: 0.9rem;"></div>
                <input type="hidden" asp-for="Estado" value="Pendiente" />

                <div class="row g-3">
                    <!-- Paciente -->
                    <div class="col-md-12">
                        <label asp-for="PacienteId" class="form-clinical-label">Paciente de Consulta *</label>
                        <select asp-for="PacienteId" class="form-select form-clinical-control select2-paciente">
                            <option value="">-- Seleccione el Paciente --</option>
                            @foreach (var pac in pacientes)
                            {
                                <option value="@pac.Id">@pac.Nombre @pac.Apellido (Cédula: @pac.Cedula)</option>
                            }
                        </select>
                        <span asp-validation-for="PacienteId" class="validation-error-msg"></span>
                    </div>

                    <!-- Médico -->
                    <div class="col-md-6">
                        <label asp-for="MedicoId" class="form-clinical-label">Médico Tratante *</label>
                        <select asp-for="MedicoId" class="form-select form-clinical-control" id="medicoSelect">
                            <option value="">-- Seleccione el Médico --</option>
                            @foreach (var med in medicos)
                            {
                                <option value="@med.Id">Dr. @med.Nombre @med.Apellido (@med.NombreEspecialidad)</option>
                            }
                        </select>
                        <span asp-validation-for="MedicoId" class="validation-error-msg"></span>
                    </div>

                    <!-- Fecha y Hora -->
                    <div class="col-md-6">
                        <label asp-for="FechaHora" class="form-clinical-label">Fecha y Hora de Cita *</label>
                        <input asp-for="FechaHora" type="datetime-local" class="form-control form-clinical-control" id="fechaHoraInput" />
                        <span asp-validation-for="FechaHora" class="validation-error-msg"></span>
                        
                        <!-- Caja de Alerta de Disponibilidad AJAX -->
                        <div id="availabilityFeedback" class="mt-2" style="display: none;">
                            <div class="d-flex align-items-center gap-1.5 p-2 rounded-3 border fw-semibold" style="font-size: 0.85rem;" id="feedbackAlert">
                                <i class="" id="feedbackIcon"></i>
                                <span id="feedbackMessage"></span>
                            </div>
                        </div>
                    </div>

                    <!-- Motivo de Consulta -->
                    <div class="col-md-12">
                        <label asp-for="Motivo" class="form-clinical-label">Motivo o Síntomas *</label>
                        <textarea asp-for="Motivo" rows="3" class="form-control form-clinical-control" placeholder="Ej: Dolor de cabeza agudo, chequeo rutinario anual, síntomas de gripe..."></textarea>
                        <span asp-validation-for="Motivo" class="validation-error-msg"></span>
                    </div>
                </div>

                <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-clinical-secondary">
                        Cancelar
                    </a>
                    <button type="submit" class="btn btn-clinical-primary" id="btnSubmitCita">
                        <i class="bi bi-calendar-check me-1"></i> Agendar Cita
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="~/js/modules/citas.js" asp-append-version="true"></script>
}

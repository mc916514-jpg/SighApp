@model IEnumerable<SighApp.Models.Cita>
@{
    ViewData["Title"] = "Agenda de Citas Médicas";
    var medicos = ViewBag.Medicos as IEnumerable<SighApp.Models.Medico> ?? new List<SighApp.Models.Medico>();
    var especialidades = ViewBag.Especialidades as IEnumerable<SighApp.Models.Especialidad> ?? new List<SighApp.Models.Especialidad>();
}

<div class="container-fluid animate-fade-in">
    <!-- Header de Módulo -->
    <div class="row align-items-center mb-4">
        <div class="col">
            <h1 class="h3 fw-bold text-dark mb-1">Citas Médicas</h1>
            <p class="text-muted mb-0">Planificación de consultas, agenda de médicos y estados de atención.</p>
        </div>
        <div class="col-auto">
            <a asp-action="Create" class="btn btn-clinical-primary">
                <i class="bi bi-calendar-plus-fill me-2"></i> Agendar Cita
            </a>
        </div>
    </div>

    <!-- Filtros de Agenda -->
    <div class="card-clinical mb-4">
        <div class="card-clinical-header">
            <h6 class="card-clinical-title d-flex align-items-center gap-2">
                <i class="bi bi-funnel-fill text-muted"></i>
                Filtros de Agenda Médica
            </h6>
        </div>
        <div class="card-clinical-body">
            <div class="row g-3">
                <!-- Rango de Fechas -->
                <div class="col-md-3">
                    <label class="form-clinical-label">Fecha Inicio</label>
                    <input type="date" id="fechaInicioFilter" class="form-control form-clinical-control" value="@ViewBag.FechaInicio" />
                </div>
                <div class="col-md-3">
                    <label class="form-clinical-label">Fecha Fin</label>
                    <input type="date" id="fechaFinFilter" class="form-control form-clinical-control" value="@ViewBag.FechaFin" />
                </div>

                <!-- Médico -->
                <div class="col-md-3">
                    <label class="form-clinical-label">Filtrar por Médico</label>
                    <select id="medicoFilter" class="form-select form-clinical-control">
                        <option value="">-- Todos los Médicos --</option>
                        @foreach (var med in medicos)
                        {
                            <option value="@med.Id" selected="@(ViewBag.MedicoId == med.Id ? "selected" : null)">Dr. @med.Nombre @med.Apellido</option>
                        }
                    </select>
                </div>

                <!-- Especialidad -->
                <div class="col-md-3">
                    <label class="form-clinical-label">Filtrar por Especialidad</label>
                    <select id="especialidadFilter" class="form-select form-clinical-control">
                        <option value="">-- Todas las Especialidades --</option>
                        @foreach (var esp in especialidades)
                        {
                            <option value="@esp.Id" selected="@(ViewBag.EspecialidadId == esp.Id ? "selected" : null)">@esp.Nombre</option>
                        }
                    </select>
                </div>

                <!-- Búsqueda por Paciente -->
                <div class="col-md-12">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0 border-slate">
                            <i class="bi bi-search text-muted"></i>
                        </span>
                        <input type="text" id="citaSearch" class="form-control form-clinical-control border-start-0" placeholder="Buscar por nombre, apellido o cédula del paciente..." value="@ViewBag.Search">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Contenedor de la Tabla AJAX -->
    <div class="card-clinical">
        <div class="card-clinical-header">
            <h5 class="card-clinical-title">Citas Agendadas</h5>
            <span class="badge bg-primary rounded-pill" id="citaCount">@Model.Count() citas encontradas</span>
        </div>
        <div class="table-responsive" id="citaTableContainer">
            @await Html.PartialAsync("_CitaTable", Model)
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/modules/citas.js" asp-append-version="true"></script>
}
